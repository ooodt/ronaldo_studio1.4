        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Get the ID of the message that just finished&#13;
var i_d = ds_map_find_value(async_load, "id");&#13;
&#13;
// Check if this is the correct message (matches our msg_id)&#13;
if (i_d == msg_id) {&#13;
    // Check if the user pressed "OK" (status is true)&#13;
    if (ds_map_find_value(async_load, "status")) {&#13;
        // Finally, get the actual name they typed&#13;
        global.player_name = ds_map_find_value(async_load, "result");&#13;
    }&#13;
}</string>
