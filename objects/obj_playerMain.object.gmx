        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Don't stuck on  walls (X axis, &lt;- -&gt;)&#13;
if not place_free(x+hspeed,y) {&#13;
hspeed = 0; }&#13;
&#13;
if not place_free(x-hspeed,y) {&#13;
hspeed = 0; }</string>
          </argument>
        </arguments>
      </action>
